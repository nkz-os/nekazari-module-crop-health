# =============================================================================
# nekazari-module-crop-health — Environment Configuration
# =============================================================================
# Copy to .env for local development. Never commit .env to git.
# =============================================================================

# --- Application --------------------------------------------------------------
APP_NAME=Crop Health Engine
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=DEBUG
API_PREFIX=/api/crop-health

# CORS: JSON array of allowed origins
CORS_ORIGINS=["http://localhost:5003","http://localhost:5173"]

# --- Keycloak / JWT -----------------------------------------------------------
KEYCLOAK_URL=https://auth.your-domain/auth
KEYCLOAK_REALM=nekazari
JWT_AUDIENCE=account

# --- Redis (temporal state for MDS sliding window) ----------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=crophealth:
SLIDING_WINDOW_HOURS=48

# --- FIWARE Orion-LD ----------------------------------------------------------
ORION_LD_URL=http://localhost:1026
ORION_LD_CONTEXT=https://uri.etsi.org/ngsi-ld/v1/ngsi-ld-core-context-v1.6.jsonld

# --- External Services --------------------------------------------------------
BIOORCHESTRATOR_URL=http://localhost:8420
SOIL_MODULE_URL=http://localhost:5000

# --- Weather DB (TimescaleDB connection for weather_observations) -------------
# WEATHER_DB_URL=postgresql://user:password@localhost:5432/nekazari

# --- Cache TTLs (seconds) ----------------------------------------------------
PHENOLOGY_CACHE_TTL=3600
WEATHER_CACHE_TTL=300

# --- Service-to-service (optional) -------------------------------------------
# MODULE_MANAGEMENT_KEY=your-secret-key
